  "roadmap": [
    {
      "id": "1A",
      "milestone": "Report Rubric Data",
      "persona": "fluentrx",
      "due": "Apr 2026",
      "status": "active",
      "notes": "Extend session report JSON with 6 rubric dimensions. Add spider chart + next-session objectives to report HTML. Data accumulates silently — no change to student output yet."
    },
    {
      "id": "1B",
      "milestone": "Split Dynamic Report into Partials",
      "persona": "fluentrx",
      "due": "Apr 2026",
      "status": "queued",
      "notes": "_dynamic_report.html.erb is 853 lines / 19k tokens — exceeds IDE agent read limit. Split into ~10 partials so agents can work on individual sections cleanly."
    },
    {
      "id": "2A",
      "milestone": "Worksheet Section Checkboxes",
      "persona": "fluentrx",
      "due": "May 2026",
      "status": "queued",
      "notes": "45 sections across pre/in/post-class. LLM generates full JSON in one call. Teacher toggles sections on/off. Display config stored separately — no re-generation needed."
    },
    {
      "id": "2B",
      "milestone": "Student Profile Integration",
      "persona": "fluentrx",
      "due": "May 2026",
      "status": "queued",
      "notes": "JSON profile per student (job, industry, goals, weaknesses, vocab mastered). Injected into worksheet generation prompt for personalised scenarios and questions."
    },
    {
      "id": "2C",
      "milestone": "Worksheet Level Differentiation",
      "persona": "fluentrx",
      "due": "May 2026",
      "status": "queued",
      "notes": "Scaffold toggle (B1/B2/C1). One worksheet generated, rendered with appropriate support layer. Parallel full versions as future premium feature."
    },
    {
      "id": "3",
      "milestone": "Student Learning Graph",
      "persona": "fluentrx",
      "due": "Jun 2026",
      "status": "planned",
      "notes": "Three new DB tables: session_assessments, learned_vocabulary, student_progress_snapshots. Background job extracts rubric data + vocab from every session report."
    },
    {
      "id": "4",
      "milestone": "Flashcards",
      "persona": "fluentrx",
      "due": "Jul 2026",
      "status": "planned",
      "notes": "Spaced repetition from learned_vocabulary. Cards carry context sentence from original session. Mobile-first web. Better than Anki because it's personalised to the student's own classes."
    },
    {
      "id": "5",
      "milestone": "Periodic Progress Review",
      "persona": "fluentrx",
      "due": "Aug 2026",
      "status": "planned",
      "notes": "Agent looks at last N sessions → structured progress report with spider chart trends + concrete transcript evidence. On-demand or scheduled. Premium add-on."
    },
    {
      "id": "6",
      "milestone": "Teacher Input Step in Reports",
      "persona": "fluentrx",
      "due": "Sep 2026",
      "status": "planned",
      "notes": "Teacher reviews AI draft → confirms/edits teacher-rated fields (pronunciation, engagement) → approves → report posts. New UI step before student notification."
    },
    {
      "id": "7",
      "milestone": "Teacher Tools SaaS",
      "persona": "coder",
      "due": "Post-May 2026",
      "status": "vision",
      "notes": "Worksheet generator (+ eventually full suite) sold to other ESL teachers. Entry price ~$15-29/mo. Built inside FluentRx Rails app — multi-tenant by teacher. Beat LinguaHouse on speed, customisation, price, personalisation."
    },
    {
      "id": "8",
      "milestone": "AI Teacher Assistant",
      "persona": "fluentrx",
      "due": "2026–2027",
      "status": "vision",
      "notes": "Agent with full access to student learning graph. Suggests session focus, flags plateaus, generates targeted exercises, supports async student practice. Amplifies the teacher — doesn't replace them."
    }
  ],
